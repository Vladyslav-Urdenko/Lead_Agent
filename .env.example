# Database Configuration
POSTGRES_USER=your_db_user_here
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=ad_master_db
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432

# Database URL for SQLAlchemy (Async)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://your_db_user_here:your_db_password_here@localhost:5432/ad_master_db

# Redis Configuration (for Celery Tasks)
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI Configuration (for AI Engine)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Serper API (Google Maps & Search)
# Get your key at: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# Email Configuration (SMTP)
# Using Gmail requires an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Telegram Bot Configuration
# Create a bot via @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ
# Get your Chat ID via @userinfobot
TELEGRAM_CHAT_ID=123456789

# App Settings
PROJECT_NAME=Ad_Master
GO_LIVE=false
